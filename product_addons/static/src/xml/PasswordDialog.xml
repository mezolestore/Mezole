<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mezole.PasswordDialog">
    <Dialog title="'Enter Password'">
        <div class="p-3">
            <input type="password"
                t-model="state.password"
                class="form-control"
                placeholder="Enter password"
                autocomplete="new-password"
                autocorrect="off"
                autocapitalize="off"
                spellcheck="false"/>

            <div t-if="state.error" class="text-danger mt-2">
                Wrong password
            </div>
        </div>

        <t t-set-slot="footer">
            <button class="btn btn-secondary" t-on-click="props.close">
                Cancel
            </button>
            <button class="btn btn-primary" t-on-click="confirm">
                Confirm
            </button>
        </t>
    </Dialog>
    </t>
</templates>