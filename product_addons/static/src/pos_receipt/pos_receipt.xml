<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_mezole.ReceiptHeader" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="attributes">
            <attribute name="style">font-size: 19px;</attribute>
        </xpath>
        <xpath expr="//img" position="replace">
            
        </xpath>
        <xpath expr="//div[@t-if='props.data.company.name']" position="attributes">
            <attribute name="style">font-size: 25px;</attribute>
        </xpath>
        <xpath expr="//div[@t-esc='props.data.cashier']" position="attributes">
            <attribute name="style">font-size: 15px;</attribute>
        </xpath>
    </t>

    <t t-name="mezole.ReceiptHeader" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-center-align')]" position="attributes">
            <attribute name="style">font-size: 22px;</attribute>
        </xpath>
    </t>
    <t t-name="pos_mezole.OrderReceiptFooter" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[@t-if='props.data.footer']" position="before">
            <br/>
            <br/>
            <div class="pos-receipt-footer" style="font-size: 15px; font-weight: 800;">
                <p class="text-muted mb-2">* No refunds.</p>
                <p class="text-muted mb-2">* Returns are accepted within 7 days only.</p>
                <p class="text-muted mb-2">* No warranty on fancy items.</p>
                <p class="text-muted mb-2">* No warranty on discounted items.</p>
                <p class="text-muted mb-2">* A 3-month warranty is provided for stiching and pasting only.</p>
            </div>
        </xpath>
        <xpath expr="//Orderline" position="inside">
            <t t-if="line.category" >
                <div class="pos-receipt-left-padding">
                    <span>Category : </span>
                    <t t-out="line.category"/>
                </div>
            </t>
        </xpath>
    </t>
</templates>