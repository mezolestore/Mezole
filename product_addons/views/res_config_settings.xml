<odoo>
    <record id="view_res_config_settings_app_password" model="ir.ui.view">
        <field name="name">res.config.settings.app.password</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//app//div[@id='invite_users']/block" position="inside">
                <setting id="app_password" title="App Password" help="Password for the apps.">
                    <field name="app_password"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
