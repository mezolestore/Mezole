<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="mz_barcode_layout_38x25" inherit_id="stock.label_product_product_view">
        <xpath expr="//t[@t-as='barcode_and_qty_by_product']" position="replace">
            <t t-foreach="quantity.items()" t-as="barcode_and_qty_by_product">
        <t t-set="product" t-value="barcode_and_qty_by_product[0]"/>
        <t t-foreach="barcode_and_qty_by_product[1]" t-as="product_info">
            <t t-set="barcode" t-value="product_info['barcode']"/>
            <t t-set="currency_id" t-value="pricelist.currency_id or product.currency_id"/>
            <t t-set="today" t-value="datetime.datetime.now()"/>
            <t t-foreach="range(product_info['quantity'])" t-as="qty">
                <t t-translation="off">
^XA^CI28
^PW600
^LL200

<t t-if="len(product_info['display_name_markup']) &lt; 20">
    ^FT30,50^A0N,25,20^FD<t t-out="product_info['display_name_markup']"/>^FS
</t>

<t t-else="">
    ^FT30,50^A0N,18,17^FD<t t-out="product_info['display_name_markup']"/>^FS
</t>


<t t-if="product.categ_id and product.categ_id.name">
^FT30,75^A0N,22,18^FD<t t-out="product.categ_id.name"/>^FS
</t>


<t t-if="price_included">
^FO260,80,1
<t t-if="currency_id.position == 'after'">
^A0N,22,22^FH^FD<t t-esc="pricelist._get_product_price(product, 1, currency_id)" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/><t t-esc="currency_id.symbol"/>^FS
</t>
<t t-if="currency_id.position == 'before'">
^A0N,22,22^FH^FD Rs. <t t-esc="product.mrp_price" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/>^FS
</t>
</t>

<t t-if="barcode">
    <t t-if="len(barcode) &lt; 9">
        ^FO30,110^BY2
        ^BCN,55,Y,N,N
        ^FD<t t-out="barcode"/>^FS
    </t>
    
    <t t-else="">
        ^FO30,110^BY1
        ^BCN,55,Y,N,N
        ^FD<t t-out="barcode"/>^FS
    </t>

</t>

^FT30,188^A0N,22,20^FD<t t-esc="today.strftime('%B')[:2].upper() + today.strftime('%y')"/>^FS

<t t-if="len(product_info['display_name_markup']) &lt; 20">
    ^FT350,50^A0N,25,20^FD<t t-out="product_info['display_name_markup']"/>^FS
</t>

<t t-else="">
    ^FT350,50^A0N,18,17^FD<t t-out="product_info['display_name_markup']"/>^FS
</t>


<t t-if="product.categ_id and product.categ_id.name">
^FT360,75^A0N,22,18^FD<t t-out="product.categ_id.name"/>^FS
</t>


<t t-if="price_included">
^FO580,80,1
<t t-if="currency_id.position == 'after'">
^A0N,22,22^FH^FD<t t-esc="pricelist._get_product_price(product, 1, currency_id)" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/><t t-esc="currency_id.symbol"/>^FS
</t>
<t t-if="currency_id.position == 'before'">
^A0N,22,22^FH^FD Rs. <t t-esc="product.mrp_price" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/>^FS
</t>
</t>

<t t-if="barcode">
    <t t-if="len(barcode) &lt; 9">
        ^FO350,110^BY2
        ^BCN,55,Y,N,N
        ^FD<t t-out="barcode"/>^FS
    </t>
    
    <t t-else="">
        ^FO360,110^BY1
        ^BCN,55,Y,N,N
        ^FD<t t-out="barcode"/>^FS
    </t>
</t>

^FT360,188^A0N,22,20^FD<t t-esc="today.strftime('%B')[:2].upper() + today.strftime('%y')"/>^FS

^XZ
                </t>
            </t>
        </t>
    </t>
            
        </xpath>
    </template>
</odoo>