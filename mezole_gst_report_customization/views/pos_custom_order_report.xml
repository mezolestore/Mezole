<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="report_pos_order_view_tree" model="ir.ui.view">
        <field name="name">report.custom.pos.order.tree</field>
        <field name="model">report.custom.pos.order</field>
        <field name="arch" type="xml">
            <tree string="Custom Order Analysis">
                <field name="id" />
                <field name="date_order" widget="date" />
                <!-- <field name="partner_id" /> -->
                <field name="config_id" />
                <field name="price_total" />
                <!-- <field name="user_id" /> -->
                <!-- <field name="session_id" /> -->
            </tree>
        </field>
    </record>
    <record id="view_report_custom_pos_order_pivot" model="ir.ui.view">
        <field name="name">report.custom.pos.order.pivot</field>
        <field name="model">report.custom.pos.order</field>
        <field name="arch" type="xml">
            <pivot string="POS Order Sales Rate">
                <field name="price_total" type="measure" />
                <!-- <field name="rosp" type="measure" /> -->
                <!-- <field name="order_id" type="measure" /> -->
                <field name="date_order" interval="month" type="row" />
            </pivot>
        </field>
    </record>
    <record id="action_custom_order_analysis_calculation" model="ir.actions.act_window">
        <field name="name">Custom Order Analysis</field>
        <field name="res_model">report.custom.pos.order</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_report_custom_pos_order_pivot" />
        <field name="target">current</field>
    </record>
    <menuitem id="menu_custom_order_analysis_calculation" name="Custom Order Analysis" parent="point_of_sale.menu_point_rep" action="action_custom_order_analysis_calculation" sequence="42" />
</odoo>